# ============================================================================
# GOAT UGC AI — environment configuration
# Copy to .env.local for development; set the same vars in Vercel for prod.
# Do NOT commit .env.local — it's already in .gitignore.
# ============================================================================

# ---- LTX Video (primary video provider) ------------------------------------
# Sign up at https://ltx.io and create an API key:
#   https://console.ltx.video/overview/
LTX_API_KEY=

# ---- fal.ai (optional — images, scene planning, TTS) -----------------------
# Only needed if you want image-to-video mode (anchor images via Flux/SDXL)
# or LLM-powered scene planning. Text-to-video works with just LTX_API_KEY.
# FAL_KEY=

# ---- Provider selection (auto-detected from keys) --------------------------
# AI_PROVIDER=ltx
